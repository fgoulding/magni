# Automatic HTTPS (Let's Encrypt) for the hostname set in .env, proxying to the
# app container. Caddy obtains and renews the certificate automatically.
#
# Optional: to get cert-expiry emails, add a global block at the very top:
#   {
#       email you@example.com
#   }

{$DOMAIN} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		-Server
	}

	reverse_proxy app:3000
}
