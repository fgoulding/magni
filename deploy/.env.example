# Production config — copy to `.env` in your private deploy repo and fill in.
# `.env` is gitignored (see .gitignore) so secrets never get committed.

# Published image to run. Use :latest so Watchtower can auto-update on each push
# to main. To PIN a version (and pause auto-updates for a rollback), set a tag
# like ...:v1.0.0 and remove the watchtower label/container.
IMAGE=ghcr.io/fgoulding/magni:latest

# Cloudflare Tunnel token. Create a tunnel in the Cloudflare Zero Trust dashboard
# (Networks → Tunnels → Create → "Cloudflared"), copy the token it shows. The
# public hostname magni.tylergould.ing → http://app:3000 is configured there too.
TUNNEL_TOKEN=

# Who may register (comma/space separated). REQUIRED — this instance is
# internet-facing. Each invited person sets their own password at /register.
REGISTER_ALLOWLIST=dont_email_me@tuta.com

# Optional: directory on the HOST that holds docker's config.json (with your GHCR
# login) for Watchtower to read. Default assumes you ran `docker login` as root.
# DOCKER_CONFIG_DIR=/root/.docker
