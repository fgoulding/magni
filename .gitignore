# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# local workspaces
.worktrees/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# local sqlite data
/data/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!*.env.example
!deploy/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.playwright-cli/

# Playwright
node_modules/
/.playwright/
/test-results*/
/playwright-report/
/.stale-test-results-*/
/.stale-playwright-report-*/
/blob-report/
/playwright/.cache/
/playwright/.auth/

# agent / editor config (not part of the app)
/.claude/
.agents/
.codex-plugins/
