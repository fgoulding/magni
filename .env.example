# Optional config for running FROM SOURCE (docker-compose.yml / `npm run dev`).
# Copy to `.env`. `.env` is gitignored. Production config lives in your private
# deploy repo instead — see deploy/.env.example.

# Who may register (comma/space separated emails). Leave UNSET = open sign-ups.
# REGISTER_ALLOWLIST=you@example.com

# Where the SQLite file lives when running outside Docker (the compose file sets
# this to a volume automatically).
# DB_PATH=./data/workouts.db
